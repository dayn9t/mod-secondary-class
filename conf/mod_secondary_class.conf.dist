########################################
# mod-secondary-class
#
# Secondary class (dual-class) system for AzerothCore WotLK 3.3.5a.
# Players gain a secondary class's spells (GM-set), synced by level, persisted,
# restorable on login. Stage 1: spells only (no talents/gear/stats).
########################################

# Master switch. When 0, all hooks return early; already-learned secondary
# spells are kept (player can .secondary unset manually).
SecondaryClass.Enable = 1

# Minimum primary level to allow setting a secondary class (1 = no gate).
SecondaryClass.MinLevel = 1

# Resource-type mismatch handling (e.g. warrior rage + mage mana):
#   0 = reject the combo (client has no mana bar to cast mage spells)
#   1 = warn but allow (player accepts spells may be uncastable)
SecondaryClass.AllowResourceMismatch = 0

# Combo whitelist, empty = all combos allowed.
# Format: "PRIMARY:SECONDARY,PRIMARY:SECONDARY" e.g. "HUNTER:MAGE,HUNTER:PRIEST"
SecondaryClass.AllowedCombos = ""

# Secondary spell unlock level offset relative to primary level.
#   0  = sync (secondary spells unlock at same level as primary)
#  -N  = delay N levels (balance; avoid low-level with full secondary kit)
SecondaryClass.SpellLevelOffset = 0

# Spell id blacklist (comma-separated). Emergency: spells that crash the client
# or are uncastable can be excluded here without code change.
SecondaryClass.SpellBlacklist = ""

########################################
# Phase 2 — cross-resource secondary power (dual-power)
#
# A physical primary (warrior rage / rogue energy / DK runic) taking a caster
# secondary has no mana bar, so its spells would cast for free (AC computes mana
# cost as % * GetCreateMana, and the base mana is 0). Phase 2 grants a real base
# mana (SetCreateMana) so cost, pool-max and regen all run through AC's native
# logic. The mana bar itself is not drawn by the 3.3.5a client for a physical
# primary — use `.secondary powerinfo` for server-side visibility.
########################################

# Phase-2 master switch. 1 = grant the synthetic mana pool for cross-resource
# combos (rogue+mage etc.); 0 = reject cross-resource combos (back to Phase-1
# behaviour, unless AllowResourceMismatch=1 forces them through without a pool).
SecondaryClass.SecondaryPowerEnabled = 1

# Synthetic base mana to grant. 0 = look up the real value for the secondary
# class + level from player_classlevel_stats (recommended, single source of
# truth). Set > 0 to override for tuning/testing.
SecondaryClass.SecondaryPowerBase = 0

# Passive mp5 as a PERCENT of the secondary's base mana, per 5 seconds, injected
# via the native ApplyManaRegenBonus mechanic. Scales with level (a flat constant
# is huge on a tiny low-level pool and trivial at 80). Low default → the secondary
# regens slower than a real caster (which has spirit+intellect+talents); drink/eat
# to refill faster (SPELL_AURA_MOD_POWER_REGEN[MANA], stacks with this). 0 = no
# passive regen (drink only). The shell tracks the injected amount per session so
# level-up/unset swap exactly (no underflow); relog after changing this.
SecondaryClass.ManaRegenPct = 3

########################################
# Phase 3 — secondary-class talents (dual-class talent tree via addon)
########################################

# Talent system master switch. 1 = enable secondary talents (re-applied on login,
# configured via the mod-secondary-class-addon over the SC addon-message channel).
# 0 = talents disabled (already-learned talents are kept until reset).
SecondaryClass.TalentEnabled = 1

# Secondary talent-point budget = (level - 9) * this ratio (WotLK: 1 pt/level from
# 10). 1.0 = same as a real secondary-class player. The secondary's weakness is
# expressed ENTIRELY through attributes (Phase 4 injects weak spell power / crit),
# NOT through the talent budget — cutting points on top would double-weaken the
# build and starve it of build diversity. Keep at 1.0. Relog after changing.
SecondaryClass.TalentPointRatio = 1.0
